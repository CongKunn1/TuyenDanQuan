{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "Environment": "Development",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TuyenDanQuan_Dev;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "ApiSettings": {
    "JwtOptions": {
      "Key": "dev-key-123456789123456789123456789abcdefasdasdasdasdasdasd",
      "Issuer": "TuyenDanQuan-Dev-API",
      "Audience": "TuyenDanQuan-Dev-Client"
    }
  },
  "DevelopmentSettings": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "EnableSensitiveDataLogging": true,
    "AutoMigrateDatabase": false
  }
}